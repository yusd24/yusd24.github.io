{% comment %}
  Unified grants entry renderer for both formats
{% endcomment %}

<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    <li class="list-group-item">
      <div class="row">
        
        {% comment %} FIX 1: Use assign instead of capture to avoid whitespace {% endcomment %}
        {% assign raw_start = entry.start_date | default: entry.startDate %}
        {% assign raw_end = entry.end_date | default: entry.endDate %}

        {% if raw_start %}
          {% comment %} 1. Split the dates into lists {% endcomment %}
          {% assign start_pieces = raw_start | strip | split: '-' %}
          
          {% comment %} 2. Combine Month [1] and Year [0] for the start date {% endcomment %}
          {% assign startDate = start_pieces[1] | append: '/' | append: start_pieces[0] %}

          {% comment %} 3. Do the same for end date, or fallback to 'Present' {% endcomment %}
          {% if raw_end %}
            {% assign end_pieces = raw_end | strip | split: '-' %}
            {% assign endDate = end_pieces[1] | append: '/' | append: end_pieces[0] %}
          {% else %}
            {% assign endDate = 'Present' %}
          {% endif %}

          {% comment %} 4. Stitch them together with a dash in the middle {% endcomment %}
          {% assign date = startDate | append: ' - ' | append: endDate %}
        {% else %}
          {% assign date = null %}
        {% endif %}

        <div class="col-xs-2 col-sm-2 col-md-2 text-center date-column">
          {% comment %} FIX 2: Removed the nested, broken column div that was here {% endcomment %}
          <table class="table-cv">
            <tbody>
              <tr>
                <td>
                  {% if date %}
                    <span class="badge font-weight-bold danger-color-dark text-uppercase align-middle" style="min-width: 75px">
                      {% comment %} FIX 3: Replaced 'pub_date' logic with your formatted 'date' variable {% endcomment %}
                      {{ date }}
                    </span>
                  {% endif %}
                </td>
              </tr>
            </tbody>
          </table>
        </div>
        
        <div class="col-xs-10 col-sm-10 col-md-10 mt-2 mt-md-0">
          
          {% if entry.url %}
            <h6 class="title font-weight-bold">
              <a href="{{ entry.url }}" target="_blank">{{ entry.name }}</a>
            </h6>
          {% else %}
            <h6 class="title font-weight-bold">{{ entry.name }}</h6>
          {% endif %}
          
          {%- if entry.authors -%}
            <h6 style="font-size: 0.85rem;">{{ entry.authors | array_to_sentence_string }}</h6>
          {%- endif -%}
          
          {% if entry.summary %}
            <p style="font-size: 0.85rem;">{{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}</p>
          {% endif %}

          {% if entry.highlights %}
            <ul class="items">
              {% for item in entry.highlights %}
                <li>
                  <span class="item" style="font-size: 0.85rem;">{{ item | markdownify | remove: '<p>' | remove: '</p>' }}</span>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
          
        </div>
      </div>
    </li>
  {% endfor %}
</ul>
