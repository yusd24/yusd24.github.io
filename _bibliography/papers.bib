@article{2022-Lau-Lee-Lin-syz-mirror-symmetry-for-del-pezzo-surfaces-and-affine-structures,
	abbr = {Adv. Math.},
	abstract = {We prove that the Landau--Ginzburg superpotential of del Pezzo surfaces can be realized as a limit of their hyperK{\"a}hler rotation toward the large complex structure limit point. As a corollary, we compute the limit of the complex affine structure of the special Lagrangian fibrations constructed by Collins--Jacob--Lin in P1×P1 [16] and compare it with the integral affine structures used in the work of Carl--Pumperla--Siebert [9]. We also construct the Floer-theoretical Landau--Ginzburg mirrors of smoothing of An-singularities and monotone del Pezzo surfaces, by using the gluing method of Cho--Hong--Lau [13] and Hong--Kim--Lau [41]. They agree with the result of limit of hyperK{\"a}hler rotations.},
	author = {Siu-Cheong Lau and Tsung-Ju Lee and Yu-Shen Lin},
	doi = {https://doi.org/10.1016/j.aim.2024.109488},
	fjournal = {Advances in Mathematics},
	issn = {0001-8708},
	journal = {Adv. Math.},
	keywords = {SYZ mirror symmetry, Del Pezzo surfaces, Rational elliptic surfaces, Affine structures, Periods, Immersed Lagrangians},
	pages = {109488},
	title = {SYZ mirror symmetry for del Pezzo surfaces and affine structures},
	url = {https://www.sciencedirect.com/science/article/pii/S0001870824000033},
	volume = {439},
	year = {2024},
	bdsk-url-1 = {https://www.sciencedirect.com/science/article/pii/S0001870824000033},
	bdsk-url-2 = {https://doi.org/10.1016/j.aim.2024.109488}}

