@article{2020-Hosono-Lee-Lian-Yau-mirror-symmetry-for-double-cover-calabi-yau-varieties,
	abbr = {J. Differential Geom.},
	abstract = {The presented paper is a continuation of the series of papers by the first, third, fourth authors, and Tagaki. In this paper, utilizing Batyrev and Borisov's duality construction on nef‑partitions, we generalize their recipe to construct a pair of singular double cover Calabi--Yau varieties $(Y,Y^\vee)$ over toric manifolds and compute their topological Euler characteristics and Hodge numbers. In the $3$-dimensional cases, we show that $(Y, Y^\vee)$ forms a topological mirror pair, i.e., $h^{p,q} (Y ) = h^{3-p,q} (Y^\vee)$ for all $p, q$.},
	author = {Shinobu Hosono and Tsung-Ju Lee and Bong H. Lian and Shing-Tung Yau},
	doi = {10.4310/jdg/1717356161},
	fjournal = {Journal of Differential Geometry},
	journal = {J. Differential Geom.},
	number = {1},
	pages = {409--431},
	publisher = {Lehigh University},
	title = {{Mirror symmetry for double cover Calabi--Yau varieties}},
	url = {https://doi.org/10.4310/jdg/1717356161},
	volume = {127},
	year = {2024},
	bdsk-url-1 = {https://doi.org/10.4310/jdg/1717356161}}

